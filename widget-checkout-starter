<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout Starter — Never Off App</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --negro: #0A0A0A; --amarillo: #FFEA2A; --blanco: #FFFFFF;
      --gris: #1A1A1A; --gris2: #222222; --verde: #22C55E;
      --borde: #2a2a2a;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--negro);
      color: var(--blanco);
      font-family: 'DM Sans', sans-serif;
      font-size: clamp(14px, 2vw, 17px);
      line-height: 1.6;
      overflow-x: hidden;
      min-height: 100vh;
    }
    h1, h2, h3 { font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.02em; line-height: 1.1; }

    /* NAVBAR */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,0.95);
      backdrop-filter: blur(12px);
      border-bottom: 2px solid var(--amarillo);
      padding: 14px 32px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .navbar-left { display: flex; align-items: center; gap: 12px; }
    .navbar-logo-text {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px;
      letter-spacing: 2px;
      color: var(--amarillo);
    }
    .navbar-back {
      font-size: clamp(12px, 1.5vw, 14px);
      color: #666;
      text-decoration: none;
      transition: color 0.2s;
    }
    .navbar-back:hover { color: var(--amarillo); }
    .navbar-secure {
      display: flex; align-items: center; gap: 6px;
      font-size: clamp(11px, 1.5vw, 13px);
      color: var(--verde);
      font-weight: 600;
    }

    /* HERO PLAN */
    .plan-hero {
      background: linear-gradient(180deg, #0f0f0f 0%, var(--negro) 100%);
      border-bottom: 1px solid var(--borde);
      padding: 40px 32px 32px;
      text-align: center;
    }
    .plan-badge {
      display: inline-block;
      background: rgba(255,234,42,0.1);
      border: 1px solid rgba(255,234,42,0.4);
      color: var(--amarillo);
      font-size: clamp(11px, 1.5vw, 13px);
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 12px;
    }
    .plan-nombre {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(42px, 8vw, 72px);
      color: #56CFE1;
      line-height: 1;
      margin-bottom: 4px;
    }
    .plan-precio-wrap {
      display: flex; align-items: baseline; justify-content: center; gap: 4px;
      margin-bottom: 8px;
    }
    .plan-precio {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(56px, 12vw, 96px);
      color: var(--amarillo);
      line-height: 1;
    }
    .plan-precio-decimal {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(28px, 5vw, 48px);
      color: var(--amarillo);
    }
    .plan-periodo {
      font-size: clamp(13px, 2vw, 16px);
      color: #888;
      margin-bottom: 16px;
    }
    .plan-fundador-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(34,197,94,0.1);
      border: 1px solid var(--verde);
      color: var(--verde);
      font-size: clamp(12px, 1.5vw, 14px);
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 100px;
    }

    /* MAIN CONTENT */
    .main {
      max-width: 960px;
      margin: 0 auto;
      padding: 48px 32px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: start;
    }

    /* COLUMNA IZQUIERDA — RESUMEN */
    .resumen { position: sticky; top: 90px; }

    .resumen-titulo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(22px, 3vw, 32px);
      color: var(--blanco);
      margin-bottom: 20px;
    }
    .resumen-titulo span { color: var(--amarillo); }

    .features-lista { list-style: none; margin-bottom: 28px; }
    .features-lista li {
      display: flex; gap: 10px; align-items: flex-start;
      padding: 10px 0;
      border-bottom: 1px solid var(--borde);
      font-size: clamp(13px, 1.8vw, 15px);
      color: var(--blanco);
      line-height: 1.5;
    }
    .features-lista li:last-child { border-bottom: none; }
    .features-lista li::before {
      content: '✅';
      font-size: 13px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .features-lista li.no { color: #555; }
    .features-lista li.no::before { content: '❌'; }

    /* BONOS RESUMEN */
    .bonos-resumen {
      background: linear-gradient(135deg, #1a1a00, #2a2400);
      border: 1px solid rgba(255,234,42,0.3);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 24px;
    }
    .bonos-resumen-titulo {
      font-size: clamp(12px, 1.5vw, 14px);
      font-weight: 700;
      color: var(--amarillo);
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .bono-item {
      display: flex; gap: 8px; align-items: flex-start;
      font-size: clamp(12px, 1.5vw, 14px);
      color: var(--blanco);
      padding: 5px 0;
      line-height: 1.5;
    }
    .bono-item::before { content: '🎁'; font-size: 13px; flex-shrink: 0; }

    /* MASCOTA */
    .mascota-wrap {
      text-align: center;
      margin-top: 8px;
    }
    .mascota {
      width: clamp(120px, 18vw, 180px);
      filter: drop-shadow(0 8px 24px rgba(255,234,42,0.25));
      animation: float 3s ease-in-out infinite;
    }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

    .garantia-mini {
      display: flex; align-items: center; gap: 8px;
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.3);
      border-radius: 12px;
      padding: 12px 16px;
      margin-top: 16px;
      font-size: clamp(12px, 1.5vw, 14px);
      color: var(--verde);
      font-weight: 600;
    }

    /* COLUMNA DERECHA — FORMULARIO */
    .checkout-wrap {
      background: var(--gris);
      border: 2px solid var(--borde);
      border-radius: 24px;
      overflow: hidden;
    }
    .checkout-header {
      background: linear-gradient(135deg, #1a1a1a, #111);
      border-bottom: 1px solid var(--borde);
      padding: 20px 24px;
    }
    .checkout-header-titulo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(18px, 2.5vw, 24px);
      color: var(--blanco);
      margin-bottom: 4px;
    }
    .checkout-header-sub {
      font-size: clamp(12px, 1.5vw, 14px);
      color: #666;
    }

    /* PLACEHOLDER FORMULARIO */
    .formulario-placeholder {
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .campo-grupo { display: flex; flex-direction: column; gap: 6px; }
    .campo-label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #666;
    }
    .campo-input {
      background: var(--gris2);
      border: 1px solid var(--borde);
      border-radius: 10px;
      padding: 14px 16px;
      color: #444;
      font-size: clamp(13px, 1.8vw, 15px);
      font-family: 'DM Sans', sans-serif;
      pointer-events: none;
    }
    .campos-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .divider-pago {
      display: flex; align-items: center; gap: 12px;
      margin: 4px 0;
    }
    .divider-pago::before,
    .divider-pago::after {
      content: ''; flex: 1;
      height: 1px; background: var(--borde);
    }
    .divider-pago span {
      font-size: 12px; color: #555;
      text-transform: uppercase; letter-spacing: 1px;
      white-space: nowrap;
    }
    .metodos-pago {
      display: flex; gap: 8px; flex-wrap: wrap;
    }
    .metodo-chip {
      background: var(--gris2);
      border: 1px solid var(--borde);
      border-radius: 8px;
      padding: 8px 14px;
      font-size: 12px;
      color: #555;
      font-weight: 600;
    }

    .btn-pagar {
      display: block;
      background: #00C851;
      color: #FFEA2A;
      font-weight: 900;
      text-shadow: 1px 1px 0 #000, 2px 2px 0 #000;
      text-transform: uppercase;
      padding: 18px;
      border-radius: 14px;
      font-size: clamp(16px, 2.5vw, 22px);
      border: none;
      width: 100%;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      letter-spacing: 1px;
      box-shadow: 0 8px 24px rgba(0,200,81,0.35);
      transition: all 0.3s;
      margin-top: 8px;
      text-align: center;
      text-decoration: none;
    }
    .btn-pagar:hover { background: #00a844; transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,200,81,0.5); }

    .placeholder-nota {
      text-align: center;
      font-size: 12px;
      color: #444;
      font-style: italic;
      padding: 0 0 8px;
    }

    .checkout-footer {
      border-top: 1px solid var(--borde);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .checkout-footer span {
      font-size: 12px;
      color: #444;
    }
    .hotmart-badge {
      display: flex; align-items: center; gap: 4px;
      font-size: 12px;
      color: #555;
      font-weight: 600;
    }

    /* FOOTER */
    .footer {
      background: #050505;
      border-top: 1px solid #1a1a1a;
      padding: 28px 24px;
      text-align: center;
      margin-top: 40px;
    }
    .footer-links {
      display: flex; justify-content: center; gap: 20px;
      margin-bottom: 10px; flex-wrap: wrap;
    }
    .footer-links a { color: #444; text-decoration: none; font-size: 12px; transition: color 0.2s; }
    .footer-links a:hover { color: var(--amarillo); }
    .footer-copy { font-size: 11px; color: #333; }

    @media (max-width: 768px) {
      .main { grid-template-columns: 1fr; padding: 32px 20px; gap: 32px; }
      .resumen { position: static; }
      .navbar { padding: 12px 20px; }
      .plan-hero { padding: 32px 20px 24px; }
      .campos-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
